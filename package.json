{
  "name": "ts-val",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist-package/lib/index.js",
  "types": "./dist-package/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-package/lib/index.d.ts",
      "import": "./dist-package/lib/index.js",
      "default": "./dist-package/lib/index.js"
    }
  },
  "files": [
    "dist-package",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:package": "rm -rf dist-package && tsc -p tsconfig.package.json",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint",
    "format": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "prettier": "3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.47.0",
    "vite": "^7.2.2",
    "vitest": "^4.0.10"
  }
}
