{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "dist-package",
    "rootDir": "src",
    "types": [],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.package.tsbuildinfo"
  },
  "include": ["src/lib/**/*", "src/types/**/*"]
}
